# Base URL of the F1 Predictor backend API (no trailing slash).
# Set this in Vercel's Environment Variables to the deployed Render URL, e.g.
#   VITE_API_URL=https://f1-predictor-api.onrender.com
# When unset (local dev), the app falls back to http://<current-host>:8000.
VITE_API_URL=http://127.0.0.1:8000
